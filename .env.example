# Session secret for cookie encryption
# Required for production. Generate with: openssl rand -hex 32
SESSION_SECRET=your-secret-here

# Gmail credentials for contact form emails
# Enable 2FA on Google → Security → App passwords → create one for "Mail"
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Where contact-form messages are delivered. Defaults to GMAIL_USER if unset.
CONTACT_TO=you@gmail.com